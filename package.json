{
  "name": "family-leaderboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A zero-cost family leaderboard for bedtime and healthy-eating habits, on Cloudflare Workers + D1.",
  "license": "MIT",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "node --test",
    "db:schema": "wrangler d1 execute family-leaderboard --local --file=schema.sql",
    "db:seed": "wrangler d1 execute family-leaderboard --local --file=seed.example.sql",
    "db:seed:local": "wrangler d1 execute family-leaderboard --local --file=seed.local.sql",
    "db:schema:remote": "wrangler d1 execute family-leaderboard --remote --file=schema.sql",
    "db:seed:local:remote": "wrangler d1 execute family-leaderboard --remote --file=seed.local.sql"
  },
  "devDependencies": {
    "wrangler": "^4"
  }
}
